# Public browser configuration (never put server secrets here)
VITE_API_BASE_URL=http://localhost:4000/api/v1

# Google Identity Services OAuth 2.0 Web Client ID
VITE_GOOGLE_CLIENT_ID=replace-with-google-web-client-id.apps.googleusercontent.com

# Razorpay key ID is public; the key secret belongs only on the server
VITE_RAZORPAY_KEY_ID=rzp_test_replace_me

# Public support address shown in the footer
VITE_SUPPORT_EMAIL=support@studynotion.local
VITE_LEGAL_ENTITY_NAME=StudyNotion local development
VITE_LEGAL_ADDRESS=Not applicable - local development
VITE_LEGAL_JURISDICTION=India
