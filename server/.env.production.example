NODE_ENV=production
PORT=4000
FRONTEND_ORIGINS=https://app.example.com
APP_URL=https://app.example.com
BRAND_NAME=StudyNotion
BRAND_LOGO_URL=https://app.example.com/logo.png
SUPPORT_EMAIL=support@example.com
MONGODB_URI=mongodb+srv://replace-with-secret-manager-value
REDIS_URL=rediss://default:replace-with-secret-manager-value@redis.example.net:6379
JWT_SECRET=replace-with-at-least-32-random-characters
OTP_SECRET=replace-with-a-different-32-character-secret
ALLOW_DEV_OTP=false

TRUST_PROXY=1
JSON_BODY_LIMIT=100kb
FORM_BODY_LIMIT=100kb
UPLOAD_MAX_BYTES=26214400
REQUEST_TIMEOUT_MS=120000
SHUTDOWN_TIMEOUT_MS=10000
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=1
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_OPERATION_TIMEOUT_MS=15000
MONGODB_SOCKET_TIMEOUT_MS=30000
MONGODB_WAIT_QUEUE_TIMEOUT_MS=10000
MONGODB_AUTO_INDEX=false

COOKIE_NAME=studynotion_session
# Leave blank for a safer host-only cookie. Set only when audited subdomain
# sharing is an explicit deployment requirement.
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=true

GOOGLE_CLIENT_ID=replace-with-google-web-client-id.apps.googleusercontent.com
RESEND_API_KEY=re_replace_me
EMAIL_FROM=StudyNotion <noreply@example.com>
EMAIL_REPLY_TO=support@example.com
CONTACT_RECIPIENT=support@example.com

RAZORPAY_KEY_ID=rzp_live_replace_me
RAZORPAY_SECRET=replace-with-secret-manager-value
RAZORPAY_WEBHOOK_SECRET=replace-with-secret-manager-value

CLOUD_NAME=replace-me
CLOUD_API_KEY=replace-me
CLOUD_API_SECRET=replace-with-secret-manager-value
FOLDER_NAME=studynotion-production
MEDIA_URL_TTL_SECONDS=3600
CHECKOUT_TTL_SECONDS=1800
RAZORPAY_TIMEOUT_MS=10000
GOOGLE_TIMEOUT_MS=10000
REFUND_WINDOW_DAYS=7
