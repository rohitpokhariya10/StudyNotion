const createDemoUser = async ({
  firstName,
  email,
  password,
  accountType,
  instructorReviewedBy,
}) => {
  const existingUser = await User.findOne({ email }).select("+policyAcceptances")
  const passwordHash = await bcrypt.hash(password, 10)
  const approvalFields =
    accountType === "Instructor"
      ? {
          approved: true,
          instructorApprovalStatus: "Approved",
          instructorReviewedAt: new Date(),
          instructorReviewedBy,
          instructorReviewNote: "Approved by the trusted local demo seed",
        }
      : {
          approved: true,
          instructorApprovalStatus: "NotApplicable",
        }

  if (existingUser) {
    const update = {
      $set: {
        firstName,
        lastName: "Demo",
        password: passwordHash,
        authProviders: ["local"],
        accountType,
        active: true,
        ...approvalFields,
      },
    }
    if (!hasCurrentPolicyAcceptance(existingUser)) {
      update.$push = {
        policyAcceptances: createPolicyAcceptance("local_seed"),
      }
    }
    await User.updateOne(
      { _id: existingUser._id },
      update
    )
    return User.findById(existingUser._id)
  }

  const profile = await Profile.create({
    about: `${accountType} demo account for local development`,
  })

  return User.create({
    firstName,
    lastName: "Demo",
    email,
    password: passwordHash,
    authProviders: ["local"],
    accountType,
    active: true,
    ...approvalFields,
    additionalDetails: profile._id,
    image: "",
    courses: [],
    policyAcceptances: [createPolicyAcceptance("local_seed")],
  })
}

const seed = async () => {
  if (process.env.NODE_ENV === "production") {
    throw new Error("Demo seed data is disabled in production")
  }

  const mongoUrl = process.env.MONGODB_URI || process.env.MONGODB_URL
  if (!mongoUrl) {
    throw new Error("MONGODB_URI is required to seed the local database")
  }

  await mongoose.connect(mongoUrl)

  const admin = await createDemoUser({
    firstName: "Admin",
    email: "admin@studynotion.local",
    password: "Admin@123",
    accountType: "Admin",
  })
  const instructor = await createDemoUser({
    firstName: "Instructor",
    email: "instructor@studynotion.local",
    password: "Instructor@123",
    accountType: "Instructor",
    instructorReviewedBy: admin._id,
  })
  const student = await createDemoUser({
    firstName: "Student",
    email: "student@studynotion.local",
    password: "Student@123",
    accountType: "Student",
  })

  const courseIds = []
  for (const demoCourse of demoCourses) {
    const category = await Category.findOneAndUpdate(
      { name: demoCourse.category },
      { $set: { description: demoCourse.categoryDescription } },
      { upsert: true, new: true, setDefaultsOnInsert: true }
    )

    const course = await Course.findOneAndUpdate(
      { courseName: demoCourse.courseName },
      {
        $set: {
          courseDescription: demoCourse.courseDescription,
          instructor: instructor._id,
          whatYouWillLearn: demoCourse.whatYouWillLearn,
          price: demoCourse.price,
          tag: demoCourse.tag,
          category: category._id,
          thumbnail: makeThumbnail(demoCourse.courseName, demoCourse.accent),
          status: "Published",
          everPublishedAt: new Date(),
          instructions: [
            "Self-paced lessons",
            "Lifetime access",
            "Practice-focused curriculum",
          ],
        },
        $setOnInsert: {
          courseContent: [],
          ratingAndReviews: [],
          studentsEnroled: [student._id],
        },
      },
      { upsert: true, new: true, setDefaultsOnInsert: true }
    )

    const lesson = await SubSection.findOneAndUpdate(
      { title: `${demoCourse.courseName} Overview` },
      {
        $set: {
          description: `A short orientation for ${demoCourse.courseName}.`,
          timeDuration: "60",
          videoDeliveryType: "upload",
          videoUrl: DEMO_VIDEO_URL,
        },
      },
      { upsert: true, new: true, setDefaultsOnInsert: true }
    )
    const section = await Section.findOneAndUpdate(
      { sectionName: `${demoCourse.courseName} — Getting Started` },
      { $addToSet: { subSection: lesson._id } },
      { upsert: true, new: true, setDefaultsOnInsert: true }
    )

    const review = await RatingAndReview.findOneAndUpdate(
      { user: student._id, course: course._id },
      {
        $set: {
          rating: 5,
          review: `A clear and practical introduction to ${demoCourse.category.toLowerCase()}.`,
        },
      },
      { upsert: true, new: true, setDefaultsOnInsert: true }
    )

    await Course.updateOne(
      { _id: course._id },
      {
        $addToSet: {
          courseContent: section._id,
          ratingAndReviews: review._id,
          studentsEnroled: student._id,
        },
      }
    )
    await Category.updateOne(
      { _id: category._id },
      { $addToSet: { courses: course._id } }
    )
    courseIds.push(course._id)
  }

  await User.updateOne(
    { _id: instructor._id },
    { $addToSet: { courses: { $each: courseIds } } }
  )
  await User.updateOne(
    { _id: student._id },
    { $addToSet: { courses: { $each: courseIds } } }
  )

  console.log("StudyNotion local demo data is ready")
}

seed()
  .catch((error) => {
    console.error("Failed to seed local data:", error)
    process.exitCode = 1
  })
  .finally(async () => {
    await mongoose.disconnect()
  })
