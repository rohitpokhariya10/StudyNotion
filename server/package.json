{
  "name": "studynotion-backend",
  "version": "1.0.0",
  "description": "StudyNotion production API",
  "private": true,
  "engines": {
    "node": ">=24 <25",
    "npm": ">=10"
  },
  "main": "index.js",
  "scripts": {
    "pretest": "npm --prefix .. run contracts:build",
    "start": "node index.js",
    "dev": "node --watch index.js",
    "seed": "node seed",
    "preflight:production": "node scripts/preflight-production.js",
    "db:backfill-security": "node scripts/backfill-security-fields.js",
    "db:indexes": "node scripts/create-indexes.js",
    "admin:provision": "node scripts/provision-admin.js",
    "test:integration": "STUDYNOTION_RUN_CATALOG_INTEGRATION=1 node --test test/catalog-v2.integration.test.js",
    "test": "node --test"
  },
  "keywords": [
    "studynotion-backend"
  ],
  "author": "Saikat Mukherjee",
  "license": "ISC",
  "dependencies": {
    "@studynotion/contracts": "0.1.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-fileupload": "^1.4.0",
    "express-rate-limit": "^8.6.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.24.1",
    "rate-limit-redis": "^6.0.0",
    "razorpay": "^2.8.6",
    "redis": "^6.1.0"
  },
  "optionalDependencies": {
    "gcp-metadata": "^5.3.0"
  }
}
