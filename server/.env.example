NODE_ENV=development
PORT=4000
FRONTEND_ORIGINS=http://localhost:3000
APP_URL=http://localhost:3000
BRAND_NAME=StudyNotion
BRAND_LOGO_URL=http://localhost:3000/logo.png
SUPPORT_EMAIL=support@example.com
MONGODB_URI=mongodb://127.0.0.1:27017/studynotion
REDIS_URL=
JWT_SECRET=replace-with-a-long-random-secret
OTP_SECRET=replace-with-an-independent-long-random-secret
ALLOW_DEV_OTP=true
TRUST_PROXY=false
JSON_BODY_LIMIT=100kb
FORM_BODY_LIMIT=100kb
UPLOAD_MAX_BYTES=26214400
REQUEST_TIMEOUT_MS=120000
SHUTDOWN_TIMEOUT_MS=10000
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=1
MONGODB_SERVER_SELECTION_TIMEOUT_MS=10000
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_OPERATION_TIMEOUT_MS=15000
MONGODB_SOCKET_TIMEOUT_MS=30000
MONGODB_WAIT_QUEUE_TIMEOUT_MS=10000
MONGODB_AUTO_INDEX=true
COOKIE_NAME=studynotion_session
COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
FOLDER_NAME=studynotion-local
MEDIA_URL_TTL_SECONDS=3600
CHECKOUT_TTL_SECONDS=1800
RAZORPAY_TIMEOUT_MS=10000
GOOGLE_TIMEOUT_MS=10000
REFUND_WINDOW_DAYS=7

# Optional: media uploads
CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=

# Transactional email. Required in production.
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=support@example.com
CONTACT_RECIPIENT=support@example.com

# Google Identity Services Web Client ID. Required in production.
GOOGLE_CLIENT_ID=

# Optional: payments
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
