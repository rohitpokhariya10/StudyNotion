{
  "name": "studynotion-client",
  "description": "This is the client side of the StudyNotion App",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "server"
  ],
  "engines": {
    "node": ">=24 <25",
    "npm": ">=10"
  },
  "dependencies": {
    "@studynotion/contracts": "0.1.0",
    "@ramonak/react-progress-bar": "^5.0.3",
    "@reduxjs/toolkit": "^2.12.0",
    "axios": "^1.3.5",
    "chart.js": "^4.3.0",
    "copy-to-clipboard": "^4.0.2",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-hook-form": "^7.43.9",
    "react-hot-toast": "^2.4.0",
    "react-icons": "^5.7.0",
    "react-markdown": "^10.1.0",
    "react-otp-input": "^3.0.0",
    "react-redux": "^9.3.0",
    "react-router-dom": "^6.30.4",
    "react-super-responsive-table": "^6.0.2",
    "react-type-animation": "^3.0.1",
    "swiper": "^14.0.5"
  },
  "scripts": {
    "postinstall": "npm run contracts:build",
    "pretest": "npm run contracts:build",
    "prebuild": "npm run contracts:build",
    "prebuild:local": "npm run contracts:build",
    "start": "vite",
    "client": "vite",
    "build": "node scripts/validate-public-env.mjs && vite build",
    "build:local": "vite build",
    "e2e:serve": "npm run build:local && npm run preview -- --host 127.0.0.1 --port 4173",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:integration": "npm run test:integration --workspace studynotion-backend",
    "test:watch": "vitest",
    "contracts:build": "npm run build --workspace @studynotion/contracts",
    "contracts:generate": "npm run openapi:generate --workspace @studynotion/contracts",
    "contracts:openapi:check": "npm run openapi:check --workspace @studynotion/contracts",
    "typecheck": "npm run typecheck --workspace @studynotion/contracts",
    "lint": "eslint src",
    "verify": "npm run typecheck && npm run contracts:openapi:check && npm run lint && npm test && npm run build:local && npm --workspace studynotion-backend test",
    "server": "cd server && npm run dev",
    "dev": "concurrently -n \"client,server\" -c \"bgBlue,bgYellow\" \"npm run client\" \"npm run server\""
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.4",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
