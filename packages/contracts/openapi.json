{
  "openapi": "3.1.0",
  "info": {
    "title": "StudyNotion API",
    "version": "2.0.0"
  },
  "paths": {
    "/api/v2/courses": {
      "get": {
        "operationId": "listCatalogCourses",
        "summary": "List published catalog courses",
        "security": [],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "description": "Full-text course search. Defaults sorting to relevance.",
            "schema": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            }
          },
          {
            "name": "categoryId",
            "in": "query",
            "required": false,
            "description": "Exact category ObjectId.",
            "schema": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "type": "string",
              "pattern": "^[A-Fa-f\\d]{24}$"
            }
          },
          {
            "name": "level",
            "in": "query",
            "required": false,
            "description": "Canonical lowercase course level.",
            "schema": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "type": "string",
              "enum": [
                "beginner",
                "intermediate",
                "advanced"
              ]
            }
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "description": "BCP-47 course language code; normalized to lowercase.",
            "schema": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "type": "string",
              "minLength": 2,
              "maxLength": 35,
              "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$"
            }
          },
          {
            "name": "minPrice",
            "in": "query",
            "required": false,
            "description": "Inclusive minimum price in INR major units.",
            "schema": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "type": "number",
              "minimum": 0,
              "maximum": 10000000
            }
          },
          {
            "name": "maxPrice",
            "in": "query",
            "required": false,
            "description": "Inclusive maximum price in INR major units.",
            "schema": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "type": "number",
              "minimum": 0,
              "maximum": 10000000
            }
          },
          {
            "name": "minRating",
            "in": "query",
            "required": false,
            "description": "Inclusive minimum canonical average rating.",
            "schema": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "type": "number",
              "minimum": 0,
              "maximum": 5
            }
          },
          {
            "name": "minDurationSeconds",
            "in": "query",
            "required": false,
            "description": "Inclusive minimum derived curriculum duration.",
            "schema": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "type": "integer",
              "minimum": 0,
              "maximum": 31536000
            }
          },
          {
            "name": "maxDurationSeconds",
            "in": "query",
            "required": false,
            "description": "Inclusive maximum derived curriculum duration.",
            "schema": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "type": "integer",
              "minimum": 0,
              "maximum": 31536000
            }
          },
          {
            "name": "sort",
            "in": "query",
            "required": false,
            "description": "Stable cursor sort. relevance requires q.",
            "schema": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "type": "string",
              "enum": [
                "relevance",
                "newest",
                "price_asc",
                "price_desc",
                "rating_desc",
                "popular"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Page size, from 1 through 50.",
            "schema": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "default": 12,
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "description": "Opaque cursor returned by the previous page.",
            "schema": {
              "$schema": "https://json-schema.org/draft/2020-12/schema",
              "type": "string",
              "minLength": 1,
              "maxLength": 2048,
              "pattern": "^[A-Za-z0-9_-]+$"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A cursor-paginated published course page.",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "const": true
                    },
                    "requestId": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 100
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "items": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string",
                                "pattern": "^[A-Fa-f\\d]{24}$"
                              },
                              "name": {
                                "type": "string",
                                "minLength": 1,
                                "maxLength": 200
                              },
                              "description": {
                                "type": "string",
                                "minLength": 1,
                                "maxLength": 10000
                              },
                              "thumbnailUrl": {
                                "type": "string",
                                "minLength": 1,
                                "maxLength": 4096
                              },
                              "price": {
                                "type": "number",
                                "minimum": 0.01,
                                "maximum": 10000000
                              },
                              "currency": {
                                "type": "string",
                                "const": "INR"
                              },
                              "instructor": {
                                "anyOf": [
                                  {
                                    "type": "object",
                                    "properties": {
                                      "id": {
                                        "type": "string",
                                        "pattern": "^[A-Fa-f\\d]{24}$"
                                      },
                                      "name": {
                                        "type": "string",
                                        "minLength": 1,
                                        "maxLength": 161
                                      },
                                      "imageUrl": {
                                        "anyOf": [
                                          {
                                            "type": "string",
                                            "minLength": 1,
                                            "maxLength": 4096
                                          },
                                          {
                                            "type": "null"
                                          }
                                        ]
                                      }
                                    },
                                    "required": [
                                      "id",
                                      "name",
                                      "imageUrl"
                                    ],
                                    "additionalProperties": false
                                  },
                                  {
                                    "type": "null"
                                  }
                                ]
                              },
                              "category": {
                                "anyOf": [
                                  {
                                    "type": "object",
                                    "properties": {
                                      "id": {
                                        "type": "string",
                                        "pattern": "^[A-Fa-f\\d]{24}$"
                                      },
                                      "name": {
                                        "type": "string",
                                        "minLength": 1,
                                        "maxLength": 120
                                      }
                                    },
                                    "required": [
                                      "id",
                                      "name"
                                    ],
                                    "additionalProperties": false
                                  },
                                  {
                                    "type": "null"
                                  }
                                ]
                              },
                              "rating": {
                                "type": "object",
                                "properties": {
                                  "average": {
                                    "type": "number",
                                    "minimum": 0,
                                    "maximum": 5
                                  },
                                  "count": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "maximum": 9007199254740991
                                  }
                                },
                                "required": [
                                  "average",
                                  "count"
                                ],
                                "additionalProperties": false
                              },
                              "durationSeconds": {
                                "type": "integer",
                                "minimum": 0,
                                "maximum": 9007199254740991
                              },
                              "level": {
                                "anyOf": [
                                  {
                                    "type": "string",
                                    "enum": [
                                      "beginner",
                                      "intermediate",
                                      "advanced"
                                    ]
                                  },
                                  {
                                    "type": "null"
                                  }
                                ]
                              },
                              "language": {
                                "anyOf": [
                                  {
                                    "type": "string",
                                    "minLength": 2,
                                    "maxLength": 35,
                                    "pattern": "^[a-z]{2,3}(?:-[a-z0-9]{2,8})*$"
                                  },
                                  {
                                    "type": "null"
                                  }
                                ]
                              },
                              "enrollmentCount": {
                                "type": "integer",
                                "minimum": 0,
                                "maximum": 9007199254740991
                              },
                              "createdAt": {
                                "type": "string",
                                "format": "date-time",
                                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
                              }
                            },
                            "required": [
                              "id",
                              "name",
                              "description",
                              "thumbnailUrl",
                              "price",
                              "currency",
                              "instructor",
                              "category",
                              "rating",
                              "durationSeconds",
                              "level",
                              "language",
                              "enrollmentCount",
                              "createdAt"
                            ],
                            "additionalProperties": false
                          }
                        },
                        "pageInfo": {
                          "type": "object",
                          "properties": {
                            "endCursor": {
                              "anyOf": [
                                {
                                  "type": "string",
                                  "minLength": 1,
                                  "maxLength": 2048,
                                  "pattern": "^[A-Za-z0-9_-]+$"
                                },
                                {
                                  "type": "null"
                                }
                              ]
                            },
                            "hasNextPage": {
                              "type": "boolean"
                            }
                          },
                          "required": [
                            "endCursor",
                            "hasNextPage"
                          ],
                          "additionalProperties": false
                        }
                      },
                      "required": [
                        "items",
                        "pageInfo"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "success",
                    "requestId",
                    "data"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "400": {
            "description": "The query or cursor is invalid.",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 100
                        },
                        "message": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 500
                        },
                        "requestId": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 100
                        },
                        "details": {
                          "type": "object",
                          "propertyNames": {
                            "type": "string"
                          },
                          "additionalProperties": {}
                        }
                      },
                      "required": [
                        "code",
                        "message",
                        "requestId"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "403": {
            "description": "The browser origin is not trusted.",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 100
                        },
                        "message": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 500
                        },
                        "requestId": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 100
                        },
                        "details": {
                          "type": "object",
                          "propertyNames": {
                            "type": "string"
                          },
                          "additionalProperties": {}
                        }
                      },
                      "required": [
                        "code",
                        "message",
                        "requestId"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "404": {
            "description": "The v2 route does not exist.",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 100
                        },
                        "message": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 500
                        },
                        "requestId": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 100
                        },
                        "details": {
                          "type": "object",
                          "propertyNames": {
                            "type": "string"
                          },
                          "additionalProperties": {}
                        }
                      },
                      "required": [
                        "code",
                        "message",
                        "requestId"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "413": {
            "description": "The request payload is too large.",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 100
                        },
                        "message": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 500
                        },
                        "requestId": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 100
                        },
                        "details": {
                          "type": "object",
                          "propertyNames": {
                            "type": "string"
                          },
                          "additionalProperties": {}
                        }
                      },
                      "required": [
                        "code",
                        "message",
                        "requestId"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "429": {
            "description": "The global API rate limit was exceeded.",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 100
                        },
                        "message": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 500
                        },
                        "requestId": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 100
                        },
                        "details": {
                          "type": "object",
                          "propertyNames": {
                            "type": "string"
                          },
                          "additionalProperties": {}
                        }
                      },
                      "required": [
                        "code",
                        "message",
                        "requestId"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          },
          "500": {
            "description": "The catalog could not be read.",
            "content": {
              "application/json": {
                "schema": {
                  "$schema": "https://json-schema.org/draft/2020-12/schema",
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "object",
                      "properties": {
                        "code": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 100
                        },
                        "message": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 500
                        },
                        "requestId": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 100
                        },
                        "details": {
                          "type": "object",
                          "propertyNames": {
                            "type": "string"
                          },
                          "additionalProperties": {}
                        }
                      },
                      "required": [
                        "code",
                        "message",
                        "requestId"
                      ],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "error"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    }
  }
}
